# OpenMetadata
OPENMETADATA_HOST=http://localhost:8585          # or your OM instance URL
OPENMETADATA_JWT_TOKEN=your_jwt_token_here       # OM personal access token

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: set true to run DataSheriff without Anthropic (tool-routed fallback mode)
DATASHERIFF_FALLBACK_MODE=false

# Slack (optional for hackathon; Socket Mode requires bot token + app token)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_APP_TOKEN=xapp-your-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_DEFAULT_CHANNEL=#datasheriff

# App
PORT=8000
ENVIRONMENT=development
